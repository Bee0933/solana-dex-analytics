                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "grafana-bigquery-datasource",
                      "version": "v0",
                      "datasource": {
                        "name": "dfoozen4vpaf4e"
                      },
                      "spec": {
                        "editorMode": "code",
                        "format": "table",
                        "location": "europe-west3",
                        "rawQuery": true,
                        "rawSql": "WITH latest AS (\n  SELECT dex_name, dex_market_share_pct, share_7d_avg, share_change_vs_7d_avg_pct,\n         ROW_NUMBER() OVER (PARTITION BY dex_name ORDER BY snapshot_date DESC) rn\n  FROM `${project}.solana_marts.fct_dex_market_share_daily`\n)\nSELECT dex_name,\n       dex_market_share_pct AS current_share_pct,\n       share_7d_avg         AS avg_7d_share_pct,\n       share_change_vs_7d_avg_pct\nFROM latest\nWHERE rn = 1\nORDER BY share_change_vs_7d_avg_pct DESC"
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
