      "panel-7": {
        "kind": "Panel",
        "spec": {
          "id": 7,
          "title": "Current 24h Volume by DEX",
          "description": "Latest trailing-24h volume per DEX with 7-day change.",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "grafana-bigquery-datasource",
                      "version": "v0",
                      "datasource": {
                        "name": "dfoozen4vpaf4e"
                      },
                      "spec": {
                        "editorMode": "code",
                        "format": "table",
                        "location": "europe-west3",
                        "rawQuery": true,
                        "rawSql": "WITH latest AS (\n  SELECT dex_name, snapshot_date, trailing_24h_volume_usd,\n         ROW_NUMBER() OVER (PARTITION BY dex_name ORDER BY snapshot_date DESC) rn\n  FROM `${project}.solana_marts.fct_dex_market_share_daily`\n),\nwk_ago AS (\n  SELECT f.dex_name, f.trailing_24h_volume_usd AS vol_7d_ago\n  FROM `${project}.solana_marts.fct_dex_market_share_daily` f\n  JOIN latest l ON f.dex_name = l.dex_name AND f.snapshot_date = DATE_SUB(l.snapshot_date, INTERVAL 7 DAY)\n  WHERE l.rn = 1\n)\nSELECT l.dex_name,\n       l.trailing_24h_volume_usd AS `24h Volume`,\n       SAFE_DIVIDE(l.trailing_24h_volume_usd - w.vol_7d_ago, w.vol_7d_ago) * 100 AS `7d Change`\nFROM latest l\nLEFT JOIN wk_ago w USING (dex_name)\nWHERE l.rn = 1"
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                }
              ],
              "transformations": [],
              "queryOptions": {}
            }
          },
          "vizConfig": {
            "kind": "VizConfig",
            "group": "stat",
            "version": "13.1.0-27822252871",
            "spec": {
              "options": {
                "colorMode": "background",
                "graphMode": "none",
                "justifyMode": "auto",
                "orientation": "horizontal",
                "percentChangeColorMode": "standard",
                "reduceOptions": {
                  "calcs": [
                    "last"
                  ],
                  "fields": "",
                  "values": true
                },
                "showPercentChange": false,
                "textMode": "value_and_name",
                "wideLayout": true
              },
              "fieldConfig": {
                "defaults": {
                  "unit": "currencyUSD",
                  "thresholds": {
                    "mode": "absolute",
                    "steps": [
                      {
                        "value": 0,
                        "color": "blue"
                      }
                    ]
                  },
                  "color": {
                    "mode": "thresholds",
                    "fixedColor": "#ad46ff"
                  }
                },
                "overrides": [
                  {
                    "matcher": {
                      "id": "byName",
                      "options": "7d Change"
                    },
                    "properties": [
                      {
                        "id": "unit",
                        "value": "percent"
                      },
                      {
                        "id": "thresholds",
                        "value": {
                          "mode": "absolute",
                          "steps": [
                            {
                              "color": "red",
                              "value": 0
                            },
                            {
                              "color": "green",
                              "value": 0
                            }
                          ]
                        }
                      }
                    ]
                  }
                ]
              }
            }
          }
        }
      },
      "panel-8": {
