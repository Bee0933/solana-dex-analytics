      "panel-4": {
        "kind": "Panel",
        "spec": {
          "id": 4,
          "title": "24h Volume WoW %",
          "description": "How today's total volume compares to 7 days ago ",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "grafana-bigquery-datasource",
                      "version": "v0",
                      "datasource": {
                        "name": "dfoozen4vpaf4e"
                      },
                      "spec": {
                        "editorMode": "code",
                        "format": "table",
                        "location": "europe-west3",
                        "rawQuery": true,
                        "rawSql": "WITH daily AS (\n  SELECT snapshot_date, SUM(trailing_24h_volume_usd) AS v\n  FROM `${project}.solana_marts.fct_dex_market_share_daily`\n  WHERE dex_name IN (${dex_name:singlequote})\n  GROUP BY snapshot_date\n),\nlatest AS (SELECT * FROM daily ORDER BY snapshot_date DESC LIMIT 1)\nSELECT SAFE_DIVIDE(l.v - p.v, p.v) * 100 AS wow_pct\nFROM latest l\nJOIN daily p ON p.snapshot_date = DATE_SUB(l.snapshot_date, INTERVAL 7 DAY)"
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                }
              ],
              "transformations": [],
