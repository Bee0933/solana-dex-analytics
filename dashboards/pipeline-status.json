                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "grafana-bigquery-datasource",
                      "version": "v0",
                      "spec": {
                        "editorMode": "code",
                        "format": "table",
                        "location": "europe-west3",
                        "rawQuery": true,
                        "rawSql": "WITH daily AS (\n  SELECT snapshot_date, COUNT(*) AS c\n  FROM `${project}.solana_raw.raw_dex_pools`\n  GROUP BY snapshot_date\n)\nSELECT\n  (SELECT c FROM daily ORDER BY snapshot_date DESC LIMIT 1) AS rows_today,\n  (SELECT ROUND(AVG(c)) FROM (SELECT c FROM daily ORDER BY snapshot_date DESC LIMIT 7)) AS rows_7d_avg"
                      },
                      "labels": {
