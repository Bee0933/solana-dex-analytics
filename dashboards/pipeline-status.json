      "panel-2": {
        "kind": "Panel",
        "spec": {
          "id": 2,
          "title": "Last Snapshot & Rows",
          "description": "Latest snapshot date and total row count per table.",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
