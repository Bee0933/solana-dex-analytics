        "spec": {
          "id": 1,
          "title": "Freshness: Hours Since Last Snapshot",
          "description": "Hours since the most recent pool snapshot. Green < 26h, yellow < 48h, red after.",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "grafana-bigquery-datasource",
                      "version": "v0",
                      "spec": {
                        "editorMode": "code",
                        "format": "table",
                        "location": "europe-west3",
                        "rawQuery": true,
                        "rawSql": "SELECT TIMESTAMP_DIFF(CURRENT_TIMESTAMP(), MAX(snapshot_at), HOUR) AS hours_since_last_snapshot\nFROM `${project}.solana_raw.raw_dex_pools`"
                      },
                      "labels": {
