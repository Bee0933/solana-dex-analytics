{
  "__inputs": [
    {
      "name": "DS_BIGQUERY",
      "label": "BigQuery",
      "description": "Google BigQuery data source for Solana analytics",
      "type": "datasource",
      "pluginId": "grafana-bigquery-datasource",
      "pluginName": "Google BigQuery"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.0.0" },
    { "type": "datasource", "id": "grafana-bigquery-datasource", "name": "Google BigQuery", "version": "2.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Freshness — Hours Since Last Snapshot",
      "description": "Hours since the most recent pool snapshot. Green < 26h, yellow < 48h, red after.",
      "datasource": { "type": "grafana-bigquery-datasource", "uid": "${DS_BIGQUERY}" },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 26 },
            { "color": "red", "value": 48 }
          ] }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["last"], "fields": "", "values": false },
        "textMode": "value"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-bigquery-datasource", "uid": "${DS_BIGQUERY}" },
          "editorMode": "code", "rawQuery": true, "format": "table", "location": "europe-west3",
          "rawSql": "SELECT TIMESTAMP_DIFF(CURRENT_TIMESTAMP(), MAX(snapshot_at), HOUR) AS hours_since_last_snapshot\nFROM `${project}.solana_raw.raw_dex_pools`"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Pool Rows — Today vs 7-Day Avg",
      "description": "Pool rows loaded for the latest snapshot vs the 7-day average.",
      "datasource": { "type": "grafana-bigquery-datasource", "uid": "${DS_BIGQUERY}" },
      "gridPos": { "h": 4, "w": 16, "x": 8, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "rows_today" }, "properties": [{ "id": "displayName", "value": "Rows Today" }] },
          { "matcher": { "id": "byName", "options": "rows_7d_avg" }, "properties": [{ "id": "displayName", "value": "Rows 7d Avg" }] }
        ]
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["last"], "fields": "", "values": true },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-bigquery-datasource", "uid": "${DS_BIGQUERY}" },
          "editorMode": "code", "rawQuery": true, "format": "table", "location": "europe-west3",
          "rawSql": "WITH daily AS (\n  SELECT snapshot_date, COUNT(*) AS c\n  FROM `${project}.solana_raw.raw_dex_pools`\n  GROUP BY snapshot_date\n)\nSELECT\n  (SELECT c FROM daily ORDER BY snapshot_date DESC LIMIT 1) AS rows_today,\n  (SELECT ROUND(AVG(c)) FROM (SELECT c FROM daily ORDER BY snapshot_date DESC LIMIT 7)) AS rows_7d_avg"
        }
      ]
    },
    {
      "id": 2,
      "type": "table",
      "title": "Tables — Last Snapshot & Rows",
      "description": "Latest snapshot date and total row count per table.",
      "datasource": { "type": "grafana-bigquery-datasource", "uid": "${DS_BIGQUERY}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "filterable": true } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "tbl" }, "properties": [{ "id": "displayName", "value": "Table" }] },
          { "matcher": { "id": "byName", "options": "last_snapshot" }, "properties": [{ "id": "displayName", "value": "Last Snapshot" }] },
          { "matcher": { "id": "byName", "options": "rows_total" }, "properties": [{ "id": "displayName", "value": "Rows" }, { "id": "unit", "value": "short" }] }
        ]
      },
      "options": { "showHeader": true, "cellHeight": "sm" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-bigquery-datasource", "uid": "${DS_BIGQUERY}" },
          "editorMode": "code", "rawQuery": true, "format": "table", "location": "europe-west3",
          "rawSql": "SELECT 'raw_dex_pools' AS tbl, MAX(snapshot_date) AS last_snapshot, COUNT(*) AS rows_total FROM `${project}.solana_raw.raw_dex_pools`\nUNION ALL SELECT 'raw_dex_market_share', MAX(snapshot_date), COUNT(*) FROM `${project}.solana_raw.raw_dex_market_share`\nUNION ALL SELECT 'fct_pool_trailing_24h', MAX(snapshot_date), COUNT(*) FROM `${project}.solana_marts.fct_pool_trailing_24h`\nUNION ALL SELECT 'fct_dex_market_share_daily', MAX(snapshot_date), COUNT(*) FROM `${project}.solana_marts.fct_dex_market_share_daily`\nORDER BY tbl"
        }
      ]
    },
    {
      "id": 4,
      "type": "table",
      "title": "Storage by Table",
      "description": "Storage footprint per table (from INFORMATION_SCHEMA.TABLE_STORAGE).",
      "datasource": { "type": "grafana-bigquery-datasource", "uid": "${DS_BIGQUERY}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "filterable": true } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "table_schema" }, "properties": [{ "id": "displayName", "value": "Dataset" }] },
          { "matcher": { "id": "byName", "options": "table_name" }, "properties": [{ "id": "displayName", "value": "Table" }] },
          { "matcher": { "id": "byName", "options": "total_rows" }, "properties": [{ "id": "displayName", "value": "Rows" }, { "id": "unit", "value": "short" }] },
          { "matcher": { "id": "byName", "options": "bytes" }, "properties": [{ "id": "displayName", "value": "Size" }, { "id": "unit", "value": "bytes" }] }
        ]
      },
      "options": { "showHeader": true, "cellHeight": "sm", "sortBy": [{ "displayName": "Size", "desc": true }] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-bigquery-datasource", "uid": "${DS_BIGQUERY}" },
          "editorMode": "code", "rawQuery": true, "format": "table", "location": "europe-west3",
          "rawSql": "SELECT 'solana_raw' AS table_schema, table_id AS table_name, row_count AS total_rows, size_bytes AS bytes\nFROM `${project}.solana_raw.__TABLES__`\nUNION ALL\nSELECT 'solana_marts', table_id, row_count, size_bytes\nFROM `${project}.solana_marts.__TABLES__`\nORDER BY bytes DESC"
        }
      ]
    }
  ],
  "refresh": "1h",
  "schemaVersion": 39,
  "tags": ["solana", "dex", "analytics", "status"],
  "templating": {
    "list": [
      {
        "name": "project",
        "type": "constant",
        "label": "Project",
        "hide": 2,
        "query": "solana-analytics-498121",
        "current": { "text": "solana-analytics-498121", "value": "solana-analytics-498121" }
      }
    ]
  },
  "time": { "from": "now-7d", "to": "now" },
  "timezone": "utc",
  "title": "Pipeline Status",
  "uid": "solana-pipeline-status",
  "version": 1,
  "weekStart": ""
}
