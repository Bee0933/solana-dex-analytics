                      "version": "v0",
                      "spec": {
                        "editorMode": "code",
                        "format": "table",
                        "location": "europe-west3",
                        "rawQuery": true,
                        "rawSql": "SELECT 'raw_dex_pools' AS tbl, MAX(snapshot_date) AS last_snapshot, COUNT(*) AS rows_total FROM `${project}.solana_raw.raw_dex_pools`\nUNION ALL SELECT 'raw_dex_market_share', MAX(snapshot_date), COUNT(*) FROM `${project}.solana_raw.raw_dex_market_share`\nUNION ALL SELECT 'fct_pool_trailing_24h', MAX(snapshot_date), COUNT(*) FROM `${project}.solana_marts.fct_pool_trailing_24h`\nUNION ALL SELECT 'fct_dex_market_share_daily', MAX(snapshot_date), COUNT(*) FROM `${project}.solana_marts.fct_dex_market_share_daily`\nORDER BY tbl"
                      },
                      "labels": {
                        "grafana.app/export-label": "grafana-bigquery-datasource-1",
