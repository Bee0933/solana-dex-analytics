  "cursorSync": "Crosshair",
  "editable": true,
  "elements": {
    "panel-1": {
      "kind": "Panel",
      "spec": {
        "data": {
          "kind": "QueryGroup",
          "spec": {
            "queries": [
              {
                "kind": "PanelQuery",
                "spec": {
                  "hidden": false,
                  "query": {
                    "datasource": {
                      "name": "dfoozen4vpaf4e"
                    },
                    "group": "grafana-bigquery-datasource",
                    "kind": "DataQuery",
                    "spec": {
                      "editorMode": "code",
                      "format": "table",
                      "location": "europe-west3",
                      "rawQuery": true,
                      "rawSql": "SELECT TIMESTAMP_DIFF(CURRENT_TIMESTAMP(), MAX(snapshot_at), HOUR) AS hours_since_last_snapshot\nFROM `${project}.solana_raw.raw_dex_pools`"
                    },
                    "version": "v0"
                  },
                  "refId": "A"
                }
              }
            ],
            "queryOptions": {},
            "transformations": []
          }
        },
        "description": "Hours since the most recent pool snapshot. Green < 26h, yellow < 48h, red after.",
        "id": 1,
        "links": [],
        "title": "Freshness — Hours Since Last Snapshot",
        "vizConfig": {
          "group": "stat",
          "kind": "VizConfig",
          "spec": {
            "fieldConfig": {
              "defaults": {
                "color": {
                  "mode": "thresholds"
                },
                "thresholds": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": 0
                    },
                    {
                      "color": "yellow",
                      "value": 26
                    },
                    {
                      "color": "red",
                      "value": 48
                    }
                  ]
                },
                "unit": "h"
              },
              "overrides": []
            },
            "options": {
              "colorMode": "background",
              "graphMode": "none",
              "justifyMode": "auto",
              "orientation": "auto",
              "reduceOptions": {
                "calcs": [
                  "last"
                ],
                "fields": "",
                "values": false
              },
              "textMode": "value",
              "wideLayout": true
            }
          },
          "version": "13.1.0-27822252871"
        }
      }
    },
    "panel-2": {
      "kind": "Panel",
      "spec": {
        "data": {
          "kind": "QueryGroup",
          "spec": {
            "queries": [
              {
                "kind": "PanelQuery",
                "spec": {
                  "hidden": false,
                  "query": {
                    "datasource": {
                      "name": "dfoozen4vpaf4e"
                    },
                    "group": "grafana-bigquery-datasource",
                    "kind": "DataQuery",
                    "spec": {
                      "editorMode": "code",
                      "format": "table",
                      "location": "europe-west3",
                      "rawQuery": true,
                      "rawSql": "SELECT 'raw_dex_pools' AS tbl, MAX(snapshot_date) AS last_snapshot, COUNT(*) AS rows_total FROM `${project}.solana_raw.raw_dex_pools`\nUNION ALL SELECT 'raw_dex_market_share', MAX(snapshot_date), COUNT(*) FROM `${project}.solana_raw.raw_dex_market_share`\nUNION ALL SELECT 'fct_pool_trailing_24h', MAX(snapshot_date), COUNT(*) FROM `${project}.solana_marts.fct_pool_trailing_24h`\nUNION ALL SELECT 'fct_dex_market_share_daily', MAX(snapshot_date), COUNT(*) FROM `${project}.solana_marts.fct_dex_market_share_daily`\nORDER BY tbl"
                    },
                    "version": "v0"
                  },
                  "refId": "A"
                }
              }
            ],
            "queryOptions": {},
            "transformations": []
          }
        },
        "description": "Latest snapshot date and total row count per table.",
        "id": 2,
        "links": [],
        "title": "Tables — Last Snapshot & Rows",
        "vizConfig": {
          "group": "table",
          "kind": "VizConfig",
          "spec": {
            "fieldConfig": {
              "defaults": {
                "custom": {
                  "align": "auto",
                  "cellOptions": {
                    "type": "auto"
                  },
                  "filterable": true,
                  "inspect": false
                }
              },
              "overrides": [
                {
                  "matcher": {
                    "id": "byName",
                    "options": "tbl"
                  },
                  "properties": [
                    {
                      "id": "displayName",
                      "value": "Table"
                    }
                  ]
                },
                {
                  "matcher": {
                    "id": "byName",
                    "options": "last_snapshot"
                  },
                  "properties": [
                    {
                      "id": "displayName",
                      "value": "Last Snapshot"
                    }
                  ]
                },
                {
                  "matcher": {
                    "id": "byName",
                    "options": "rows_total"
                  },
                  "properties": [
                    {
                      "id": "displayName",
                      "value": "Rows"
                    },
                    {
                      "id": "unit",
                      "value": "short"
                    }
                  ]
                }
              ]
            },
            "options": {
              "cellHeight": "sm",
              "showHeader": true
            }
          },
          "version": "13.1.0-27822252871"
        }
      }
    },
    "panel-3": {
      "kind": "Panel",
      "spec": {
        "data": {
          "kind": "QueryGroup",
          "spec": {
            "queries": [
              {
                "kind": "PanelQuery",
                "spec": {
                  "hidden": false,
                  "query": {
                    "datasource": {
                      "name": "dfoozen4vpaf4e"
                    },
                    "group": "grafana-bigquery-datasource",
                    "kind": "DataQuery",
                    "spec": {
                      "editorMode": "code",
                      "format": "table",
                      "location": "europe-west3",
                      "rawQuery": true,
                      "rawSql": "WITH daily AS (\n  SELECT snapshot_date, COUNT(*) AS c\n  FROM `${project}.solana_raw.raw_dex_pools`\n  GROUP BY snapshot_date\n)\nSELECT\n  (SELECT c FROM daily ORDER BY snapshot_date DESC LIMIT 1) AS rows_today,\n  (SELECT ROUND(AVG(c)) FROM (SELECT c FROM daily ORDER BY snapshot_date DESC LIMIT 7)) AS rows_7d_avg"
                    },
                    "version": "v0"
                  },
                  "refId": "A"
                }
              }
            ],
            "queryOptions": {},
            "transformations": []
          }
        },
        "description": "Pool rows loaded for the latest snapshot vs the 7-day average.",
        "id": 3,
        "links": [],
        "title": "Pool Rows — Today vs 7-Day Avg",
        "vizConfig": {
          "group": "stat",
          "kind": "VizConfig",
          "spec": {
            "fieldConfig": {
              "defaults": {
                "color": {
                  "mode": "thresholds"
                },
                "thresholds": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "blue",
                      "value": 0
                    }
                  ]
                },
                "unit": "short"
              },
              "overrides": [
                {
                  "matcher": {
                    "id": "byName",
                    "options": "rows_today"
                  },
                  "properties": [
                    {
                      "id": "displayName",
                      "value": "Rows Today"
                    }
                  ]
                },
                {
                  "matcher": {
                    "id": "byName",
                    "options": "rows_7d_avg"
                  },
                  "properties": [
                    {
                      "id": "displayName",
                      "value": "Rows 7d Avg"
                    }
                  ]
                }
              ]
            },
            "options": {
              "colorMode": "value",
              "graphMode": "none",
              "justifyMode": "auto",
              "orientation": "auto",
              "reduceOptions": {
                "calcs": [
                  "last"
                ],
                "fields": "",
                "values": true
              },
              "textMode": "value_and_name",
              "wideLayout": true
            }
          },
          "version": "13.1.0-27822252871"
        }
      }
    },
    "panel-4": {
      "kind": "Panel",
      "spec": {
        "data": {
          "kind": "QueryGroup",
          "spec": {
            "queries": [
              {
                "kind": "PanelQuery",
                "spec": {
                  "hidden": false,
                  "query": {
                    "datasource": {
                      "name": "dfoozen4vpaf4e"
                    },
                    "group": "grafana-bigquery-datasource",
                    "kind": "DataQuery",
                    "spec": {
                      "editorMode": "code",
                      "format": "table",
                      "location": "europe-west3",
                      "rawQuery": true,
                      "rawSql": "SELECT table_schema, table_name, total_rows, total_logical_bytes AS bytes\nFROM `${project}.region-europe-west3.INFORMATION_SCHEMA.TABLE_STORAGE`\nWHERE table_schema IN ('solana_raw','solana_marts')\nORDER BY total_logical_bytes DESC"
                    },
                    "version": "v0"
                  },
                  "refId": "A"
                }
              }
            ],
            "queryOptions": {},
            "transformations": []
          }
        },
        "description": "Storage footprint per table (from INFORMATION_SCHEMA.TABLE_STORAGE).",
        "id": 4,
        "links": [],
        "title": "Storage by Table",
        "vizConfig": {
          "group": "table",
          "kind": "VizConfig",
          "spec": {
            "fieldConfig": {
              "defaults": {
                "custom": {
