      "panel-6": {
        "kind": "Panel",
        "spec": {
          "id": 6,
          "title": "Pool Fee Rate Comparison",
          "description": "Fee rate of established pools (filtered by minimum active days).",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "grafana-bigquery-datasource",
                      "version": "v0",
                      "spec": {
                        "editorMode": "code",
                        "format": "table",
                        "location": "europe-west3",
                        "rawQuery": true,
                        "rawSql": "WITH latest AS (\n  SELECT pool_address, base_token_symbol, quote_token_symbol, dex_name, fee_rate_pct,\n         ROW_NUMBER() OVER (PARTITION BY pool_address ORDER BY snapshot_date DESC) rn\n  FROM `${project}.solana_marts.fct_pool_trailing_24h`\n)\nSELECT\n  CONCAT(COALESCE(l.base_token_symbol,'?'),'/',COALESCE(l.quote_token_symbol,'?'),' · ',l.dex_name) AS pool,\n  l.fee_rate_pct\nFROM latest l\nJOIN `${project}.solana_marts.dim_pool` p USING (pool_address)\nWHERE l.rn = 1\n  AND p.snapshot_days_count >= ${min_active_days}\nORDER BY l.fee_rate_pct DESC\nLIMIT 25"
                      },
                      "labels": {
                        "grafana.app/export-label": "grafana-bigquery-datasource-1",
                        "grafana.app/export-datasource-name": "grafana-bigquery-datasource"
