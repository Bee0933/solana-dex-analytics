    "panel-5": {
      "kind": "Panel",
      "spec": {
        "data": {
          "kind": "QueryGroup",
          "spec": {
            "queries": [
              {
                "kind": "PanelQuery",
                "spec": {
                  "hidden": false,
                  "query": {
                    "datasource": {
                      "name": "dfoozen4vpaf4e"
                    },
                    "group": "grafana-bigquery-datasource",
                    "kind": "DataQuery",
                    "spec": {
                      "editorMode": "code",
                      "format": "table",
                      "location": "europe-west3",
                      "rawQuery": true,
                      "rawSql": "SELECT\n  CONCAT(COALESCE(base_token_symbol,'?'),'/',COALESCE(quote_token_symbol,'?'),' · ',dex_name) AS pool,\n  SUM(trailing_24h_fees_usd) AS fees_window\nFROM `${project}.solana_marts.fct_pool_trailing_24h`\nWHERE $__timeFilter(TIMESTAMP(snapshot_date))\n  AND dex_name IN (${dex_name:singlequote})\nGROUP BY pool\nORDER BY fees_window DESC\nLIMIT 20"
                    },
                    "version": "v0"
                  },
                  "refId": "A"
                }
              }
            ],
            "queryOptions": {},
            "transformations": []
          }
        },
        "description": "Pools generating the most fees over the selected window — where LP returns concentrate.",
        "id": 5,
        "links": [],
        "title": "Top 20 Pools by Fee Revenue",
